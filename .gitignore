# =============================================================================
# ANTIGRAVITY OS — Hybrid AI Agent Architecture
# .gitignore — Python Backend + React/Next.js Frontend
# =============================================================================

# =============================================================================
# ENVIRONMENT & SECRETS — NEVER COMMIT THESE
# =============================================================================
.env
.env.*
!.env.example
*.env
.envrc
secrets.toml
*.pem
*.key
*.cert
*.p12

# =============================================================================
# PYTHON — BACKEND
# =============================================================================

# Virtual environments
venv/
.venv/
env/
ENV/
virtualenv/
.virtualenv/
Pipfile.lock

# Python cache & bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/

# Type checkers & linters
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# pyenv / poetry / pdm
.python-version
poetry.lock
pdm.lock
.pdm.toml

# =============================================================================
# FASTAPI / BACKEND SPECIFIC
# =============================================================================

# Temporary sandbox session directories
backend/temp/
backend/.cache/
temp/
tmp/

# Database files
*.db
*.sqlite
*.sqlite3

# Upload & artifact outputs
uploads/
artifacts/
outputs/
sessions/

# Logs
*.log
logs/
*.log.*

# =============================================================================
# NODE.JS / REACT / NEXT.JS — FRONTEND
# =============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build output
frontend/.next/
.next/
out/
build/

# Production build
frontend/dist/
dist/

# Cache
.npm
.eslintcache
.stylelintcache
frontend/.cache/
.cache/

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# Turbopack
.turbo/

# =============================================================================
# IDE & EDITOR
# =============================================================================

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json

# JetBrains IDEs (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# MISC
# =============================================================================

# Compressed files
*.zip
*.tar.gz
*.rar
*.7z

# Binary / model weights (too large for Git)
*.bin
*.pkl
*.pt
*.pth
*.onnx
*.h5
*.safetensors

# LangChain / AutoGen runtime cache
.langchain/
autogen_cache/

# OS thumbnails & indexes
*.bak
*.tmp
*.temp
